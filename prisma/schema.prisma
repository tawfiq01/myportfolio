// Content entities for the portfolio (PLAN.md Phase 2, first slice).
// Shapes mirror the types in lib/content.ts — queries in lib/queries.ts map
// rows back to those types so components never see Prisma models directly.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String
  tech        String[]
  href        String?
  imageUrl    String?
  highlight   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GalleryImage {
  id        String   @id @default(cuid())
  title     String   @default("")
  imageUrl  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Header/drawer navigation, orderable and toggleable from the admin panel.
model MenuItem {
  id        String   @id @default(cuid())
  label     String
  href      String
  sortOrder Int      @default(0)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Experience {
  id         String   @id @default(cuid())
  role       String
  company    String
  companyUrl String?
  start      String
  end        String?
  summary    String
  highlights String[]
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SkillGroup {
  id        String   @id @default(cuid())
  label     String
  items     String[]
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Certification {
  id        String   @id @default(cuid())
  name      String
  issuer    String
  year      String
  href      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Singleton row (id = "singleton") holding all site-wide copy: hero, about,
// contact and social links. Public pages fall back to lib/content.ts when
// the row doesn't exist yet.
model SiteContent {
  id              String   @id @default("singleton")
  heroGreeting    String
  heroHeadline    String
  heroTagline     String
  heroIntro       String
  // Existing rows get the default when db push adds the column.
  location        String   @default("Located in Bangladesh")
  aboutParagraphs String[]
  contactBlurb    String
  contactCtaLabel String
  email           String
  github          String
  linkedin        String
  updatedAt       DateTime @updatedAt
}

// Singleton row (id = "singleton") for site appearance: brand colors and
// whether visitors get a light/dark toggle. Colors are hex (#rrggbb); all
// derived shades come from CSS color-mix, so two colors define the scheme.
model ThemeSettings {
  id          String   @id @default("singleton")
  accent      String   @default("#455ce9")
  background  String   @default("#1c1d20")
  themeToggle Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}

// Singleton row (id = "singleton") for admin credentials. When present, the
// scrypt-hashed password here wins over the ADMIN_PASSWORD env var (which
// remains only as the bootstrap password before the first change).
model AdminSettings {
  id           String   @id @default("singleton")
  passwordHash String
  updatedAt    DateTime @updatedAt
}

// Contact-form submissions (wired up in Phase 3).
model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  body      String
  createdAt DateTime @default(now())
}
